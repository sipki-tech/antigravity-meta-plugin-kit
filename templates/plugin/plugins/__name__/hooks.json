{
  "{{name}}": {
    "PreToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/example-guard.mjs",
            "timeout": 10,
            "statusMessage": "{{name}}: example guard"
          }
        ]
      }
    ]
  }
}
